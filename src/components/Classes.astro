---
const classes = [
  {
    name: "Muay Thai",
    schedule: "Mon / Wed / Fri · All levels",
    badge: "Popular",
  },
  {
    name: "Brazilian Jiu-Jitsu",
    schedule: "Tue / Thu / Sat · Gi & No-Gi",
    badge: null,
  },
  {
    name: "MMA Fundamentals",
    schedule: "Wed / Sat · Beginner friendly",
    badge: null,
  },
  { name: "Kids & Teens", schedule: "Sat · Ages 6–16", badge: "New" },
  // TODO: replace schedule data with real times from owner
];
---

<section class="classes-section">
  <div class="classes-inner">
    <div class="classes-header">
      <span class="classes-label">What we teach</span>
      <h2 class="classes-title">OUR CLASSES</h2>
    </div>

    <ul class="classes-list" role="list">
      {
        classes.map((cls, i) => (
          <li class:list={["class-card", { "class-card--active": i === 0 }]}>
            <div class="class-card__left">
              <span class="class-card__name">{cls.name}</span>
              <span class="class-card__schedule">{cls.schedule}</span>
            </div>
            {cls.badge && (
              <div class="class-card__right">
                <span class="class-badge">{cls.badge}</span>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .classes-section {
    background: #0a0a0a;
    padding: 48px 24px;
  }

  .classes-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .classes-header {
    margin-bottom: 32px;
  }

  .classes-label {
    display: block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #cc1c1c;
    margin-bottom: 8px;
  }

  .classes-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 44px;
    color: #f5f5f5;
    margin: 0;
    line-height: 1;
  }

  .classes-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .class-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #111;
    border-left: 3px solid transparent;
    padding: 20px 20px;
  }

  .class-card--active {
    background: #161616;
    border-left-color: #cc1c1c;
  }

  .class-card__left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .class-card__name {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    color: #f5f5f5;
    line-height: 1.2;
  }

  .class-card__schedule {
    font-family: "Barlow", sans-serif;
    font-size: 13px;
    color: #666;
    line-height: 1.4;
  }

  .class-card__right {
    flex-shrink: 0;
    margin-left: 16px;
  }

  .class-badge {
    display: inline-block;
    background: #cc1c1c;
    color: #fff;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 6px 12px;
    border-radius: 0;
  }
</style>
