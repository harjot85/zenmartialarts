---
import Layout from "../layouts/Layout.astro";
import ScheduleGrid from "../components/ScheduleGrid.astro";
---

<Layout
  title="Class Schedule | Zen MMA — Chilliwack, BC"
  description="View the full weekly class schedule at Zen MMA in Chilliwack, BC. Muay Thai, BJJ, Kickboxing, Kids classes and more."
  canonicalURL="https://zenmartialarts.ca/schedule"
>
  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="page-label">Chilliwack, BC</span>
      <h1 class="page-title">WEEKLY SCHEDULE</h1>
      <p class="page-subtitle">
        Mon–Fri 6:00am–9:30pm · Sat 8:00am–9:30pm · Sun Closed
      </p>
      <p class="page-note">
        Weekend &amp; private training available — call
        <a href="tel:+17788356590" class="page-note-link">778-835-6590</a>
      </p>
    </div>
  </div>

  <ScheduleGrid />
</Layout>

<style>
  .page-hero {
    background: #0a0a0a;
    padding: 48px 24px 32px;
  }

  .page-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-label {
    display: block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-accent);
    margin-bottom: 10px;
  }

  .page-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 64px;
    color: #f5f5f5;
    margin: 0 0 12px;
    line-height: 1;
  }

  .page-subtitle {
    font-family: "Barlow", sans-serif;
    font-size: 15px;
    color: var(--color-secondary);
    margin: 0 0 8px;
    line-height: 1.5;
  }

  .page-note {
    font-family: "Barlow", sans-serif;
    font-size: 13px;
    color: #555;
    margin: 0;
    line-height: 1.5;
  }

  .page-note-link {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
