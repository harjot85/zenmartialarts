<style>
  .site-footer {
    background: #050505;
    border-top: 1px solid #1a1a1a;
    padding: 28px 24px;
  }

  .footer-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .footer-logo {
    font-family: "Bebas Neue", sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    color: #fff;
    margin: 0 0 6px;
    line-height: 1;
  }

  .footer-logo-accent {
    color: var(--color-accent);
  }

  .footer-address {
    font-family: "Barlow", sans-serif;
    font-size: 13px;
    color: #555;
    line-height: 1.7;
    font-style: normal;
    margin: 0 0 16px;
  }

  .footer-address-link {
    color: #555;
    text-decoration: none;
  }

  .footer-address-link:hover {
    color: #888;
  }

  .footer-hours {
    font-family: "Barlow", sans-serif;
    font-size: 13px;
    color: #555;
    line-height: 1.7;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #1a1a1a;
  }

  .footer-nav-link {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #555;
    text-decoration: none;
  }

  .footer-nav-link:hover {
    color: #888;
  }

  .footer-copy {
    font-family: "Barlow", sans-serif;
    font-size: 12px;
    color: #333;
    margin: 16px 0 0;
  }
</style>
