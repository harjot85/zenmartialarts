---
interface Props {
  headline: string;
  message: string;
}
const { headline, message } = Astro.props;
---

<section class="cs-section">
  <div class="cs-inner">
    <span class="cs-label">Under Construction</span>
    <h1 class="cs-headline">{headline}</h1>
    <p class="cs-message">{message}</p>
    <div class="cs-actions">
      <a href="/#trial" class="cs-btn cs-btn--primary">Book a Free Trial</a>
      <a href="/" class="cs-btn cs-btn--ghost">Back to Home</a>
    </div>
  </div>
</section>

<style>
  .cs-section {
    background: #0a0a0a;
    min-height: calc(100dvh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 24px;
  }

  .cs-inner {
    max-width: 560px;
    text-align: center;
  }

  .cs-label {
    display: inline-block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 6px 14px;
    margin-bottom: 28px;
  }

  .cs-headline {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(48px, 10vw, 80px);
    color: #f5f5f5;
    line-height: 1;
    margin: 0 0 20px;
  }

  .cs-message {
    font-family: "Barlow", sans-serif;
    font-size: 16px;
    color: #666;
    line-height: 1.7;
    margin: 0 0 40px;
  }

  .cs-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  @media (min-width: 480px) {
    .cs-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .cs-btn {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 14px 32px;
    text-decoration: none;
    border-radius: 0;
    transition: opacity 0.15s;
  }

  .cs-btn:hover {
    opacity: 0.85;
  }

  .cs-btn--primary {
    background: var(--color-accent);
    color: #0a0a0a;
  }

  .cs-btn--ghost {
    background: transparent;
    color: #f5f5f5;
    border: 1px solid #333;
  }

  .cs-btn--ghost:hover {
    border-color: #555;
    opacity: 1;
  }
</style>
