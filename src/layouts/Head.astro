---
import "@fontsource/bebas-neue/400.css";
import "@fontsource/barlow-condensed/400.css";
import "@fontsource/barlow-condensed/600.css";
import "@fontsource/barlow/400.css";
import "@fontsource/barlow/600.css";
import "../styles/design-tokens.css";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalURL: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage } = Astro.props;

const ogImageAbsolute = ogImage ? new URL(ogImage, Astro.site).href : undefined;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Zen MMA",
  address: {
    "@type": "PostalAddress",
    streetAddress: "48640 Yale Rd",
    addressLocality: "Chilliwack",
    addressRegion: "BC",
    postalCode: "V4Z 0B1",
    addressCountry: "CA",
  },
  telephone: "+17788356590",
  url: "https://zenmartialarts.ca",
  openingHours: [
    "Mo 06:00-21:30",
    "Tu 06:00-21:30",
    "We 06:00-21:30",
    "Th 06:00-21:30",
    "Fr 06:00-21:30",
    "Sa 08:00-21:30",
  ],
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageAbsolute && <meta property="og:image" content={ogImageAbsolute} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />

<!-- LocalBusiness JSON-LD -->
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(localBusinessSchema)}
/>

<!-- Slot for per-page JSON-LD (e.g. FAQPage, Event, BreadcrumbList) -->
<slot name="jsonld" />
